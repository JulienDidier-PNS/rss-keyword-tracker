# URL de base de l'app Flask rss-keyword-tracker. En docker-compose (même
# réseau), c'est le nom du service ; en dev local hors Docker, localhost.
FLASK_BASE_URL=http://rss-tracker:8000

# Secret partagé avec Flask : Configuration -> Demandes (WhatsApp) -> section
# "Connexion du bot" dans l'app rss-keyword-tracker. Obligatoire (le bot
# refuse de démarrer sans).
BOT_SHARED_SECRET=

# JID(s) du/des groupe(s) autorisés à utiliser le bot, séparés par des
# virgules (ex. 120363012345678901@g.us). Laisser vide au premier lancement :
# le JID de tout groupe où le bot reçoit un message est affiché dans les logs
# ("message ignoré, groupe non autorisé : ...") — copie-le ici une fois trouvé.
ALLOWED_GROUP_JIDS=

# Qualité appliquée par défaut aux demandes créées via le bot.
DEFAULT_QUALITY=1080p

# Dossier où Baileys persiste la session WhatsApp (credentials multi-device).
# À monter en volume : le perdre oblige à rescanner le QR code.
SESSION_DIR=./auth
