# Copie ce fichier en .env (non versionné) à la racine du projet : docker
# compose le lit automatiquement pour le service whatsapp-bot.

# Secret partagé avec Flask (header X-Bot-Secret sur /api/bot/requests).
# Généré automatiquement au premier démarrage de rss-tracker : démarre-le une
# fois, récupère la valeur sur Configuration -> Demandes (WhatsApp), colle-la
# ici, puis (re)démarre whatsapp-bot.
BOT_SHARED_SECRET=

# JID(s) du/des groupe(s) autorisés à utiliser le bot, séparés par des
# virgules (ex. 120363012345678901@g.us). Vide = tous les groupes où le bot
# est membre (déconseillé) ; voir whatsapp-bot/.env.example pour comment
# récupérer ce JID lors de la première configuration.
ALLOWED_GROUP_JIDS=

# Qualité appliquée par défaut aux demandes créées via le bot.
DEFAULT_QUALITY=1080p
